          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  pb.name AS brand,\n  COUNT(p.id) AS products\nFROM market.product_brands AS pb\nLEFT JOIN market.products AS p ON p.brand_id = pb.id\nGROUP BY pb.id, pb.name\nORDER BY products DESC, brand ASC\nLIMIT 50;",
