      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH product_registration AS (\n  SELECT\n    p.id,\n    p.super_market_id,\n    MIN(ph.created_at) AS registered_at\n  FROM market.products AS p\n  JOIN market.products_history AS ph ON ph.product_id = p.id\n  GROUP BY p.id, p.super_market_id\n)\nSELECT\n  $__timeGroupAlias(pr.registered_at, '1d'),\n  sm.name AS metric,\n  COUNT(*) AS value\nFROM product_registration AS pr\nJOIN market.super_markets AS sm ON sm.id = pr.super_market_id\nWHERE $__timeFilter(pr.registered_at)\nGROUP BY 1, sm.name\nORDER BY 1;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Products Registered per Market",
      "type": "timeseries"
    },
