      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  u.username,\n  COALESCE(sl.name, 'Temporary list') AS shopping_list,\n  COUNT(si.id) FILTER (WHERE si.deleted_at IS NULL) AS item_count\nFROM shopping.users AS u\nJOIN shopping.shopping_list_ownerships AS slo ON slo.user_uid = u.id\nJOIN shopping.shopping_lists AS sl ON sl.id = slo.shopping_list_id\nLEFT JOIN shopping.shopping_items AS si ON si.shopping_list_id = sl.id\nWHERE sl.deleted_at IS NULL\nGROUP BY u.username, sl.id, sl.name\nORDER BY u.username ASC, item_count DESC, shopping_list ASC;",
          "refId": "A",
          "sql": {
            "columns": [
